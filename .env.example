# Django Configuration
DEBUG=False
SECRET_KEY=your-super-secret-key-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database Configuration (PostgreSQL)
DB_NAME=hostel_management
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:your-secure-password@db:5432/hostel_management

# Redis Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email Configuration (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@hostelmanagement.com
EMAIL_USE_TLS=True

# For Console Email Backend (Development)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Application Settings
TIMEZONE=Asia/Kolkata
LANGUAGE_CODE=en-us

# Celery Configuration
CELERY_TIMEZONE=Asia/Kolkata
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY={"default-src": ["'self'"]}

# Logging
LOG_LEVEL=INFO

# AWS Configuration (Optional - for S3 media storage)
# USE_S3=False
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
